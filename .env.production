# 页面标题
VITE_APP_TITLE = intelligent-community-admin

# 生产环境配置
VITE_APP_ENV = 'production'

# 智能社区管理系统/生产环境 API 基础地址
# 生产环境需由 nginx 或其他反向代理将 /api 请求转发到后端服务（如 http://localhost:3000）
VITE_API_BASE = /api

# 兼容 RuoYi 原始变量（生产环境由 nginx 反代 /api）
VITE_APP_BASE_API = '/api'

# 是否在打包时开启压缩
VITE_BUILD_COMPRESS = gzip
