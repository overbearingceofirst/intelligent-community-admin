# 页面标题
VITE_APP_TITLE = 智能社区管理系统

# 开发环境配置
VITE_APP_ENV = 'development'

# 智能社区后端 API（开发环境通过 Vite dev-server proxy 转发到 http://localhost:3000）
# 如需修改后端地址，请同步修改 vite.config.ts 中的 baseUrl 变量
VITE_APP_BASE_API = '/dev-api'

# 后端真实地址（供说明，实际由 vite.config.ts proxy 使用）
# VITE_API_BASE = http://localhost:3000/api
