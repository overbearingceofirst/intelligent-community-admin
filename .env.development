# 页面标题
VITE_APP_TITLE = intelligent-community-admin

# 开发环境配置
VITE_APP_ENV = 'development'

# 智能社区管理系统/开发环境 API 基础地址
# 注意：开发时实际请求通过 VITE_APP_BASE_API='/api'，再由 vite.config.ts 代理到此地址
VITE_API_BASE = http://localhost:3000/api

# 兼容 RuoYi 原始变量（指向 vite proxy 路径，由 vite.config.ts 转发到后端）
VITE_APP_BASE_API = '/api'

# 是否在打包时开启压缩
VITE_BUILD_COMPRESS = gzip
